{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source scraping the Hypershop api `/metrics` endpoint.",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" }
  ],
  "title": "Hypershop — Product Page Video (Module 35)",
  "uid": "hypershop-module-35",
  "version": 1,
  "schemaVersion": 39,
  "editable": true,
  "graphTooltip": 1,
  "tags": ["hypershop", "product-videos", "module-35"],
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Data source",
        "query": "prometheus",
        "current": {
          "selected": false,
          "text": "${DS_PROMETHEUS}",
          "value": "${DS_PROMETHEUS}"
        },
        "hide": 0,
        "refresh": 1
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "name": "Deploys",
        "datasource": { "type": "datasource", "uid": "grafana" },
        "enable": false,
        "iconColor": "blue",
        "type": "tags",
        "tags": ["deploy", "module-35"]
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "1 · Pipeline health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "type": "timeseries",
      "title": "Status distribution",
      "description": "Current count of product_videos rows in each lifecycle status. Stacked area = at-a-glance pipeline shape.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "expr": "product_video_status_count",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 35,
            "stacking": { "mode": "normal", "group": "A" }
          },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Uploaded queue + oldest age",
      "description": "Left axis: rows in `uploaded` (worker-pending). Right axis: age of oldest uploaded row in seconds. SLO: oldest_secs < 90 for > 5min ⇒ page on-call.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "expr": "product_video_status_count{status=\"uploaded\"}",
          "legendFormat": "uploaded count"
        },
        {
          "refId": "B",
          "expr": "product_video_uploaded_oldest_seconds",
          "legendFormat": "oldest (s)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "oldest (s)" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "custom.axisPlacement", "value": "right" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "red", "value": 90 }
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Worker in-flight",
      "description": "Rows currently in `processing`. Steady-state = product_video_max_concurrent_jobs ± 1. Spike = worker stuck on a slow job.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "expr": "product_video_processing_in_flight",
          "legendFormat": "in-flight"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 20 },
          "unit": "short",
          "min": 0
        }
      }
    },
    {
      "id": 200,
      "type": "row",
      "title": "2 · Performance",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "FFmpeg duration p50 / p95",
      "description": "End-to-end pipeline time per video (probe + thumbnail + 720p + 360p + Bunny upload). Recorded by jobs._process_one. Target p95 < 90s for a 30s clip on the default 2-CPU worker.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum by (le) (rate(product_video_ffmpeg_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(product_video_ffmpeg_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 5 },
          "unit": "s"
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Bunny PUT latency p95",
      "description": "Per-PUT latency to Bunny Storage, success path only. Sub-second drift = regional carrier latency change; >5s p95 = Bunny edge issue or auth retries.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(product_video_bunny_upload_duration_seconds_bucket{outcome=\"success\"}[5m])))",
          "legendFormat": "success p95"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.5, sum by (le) (rate(product_video_bunny_upload_duration_seconds_bucket{outcome=\"error\"}[5m])))",
          "legendFormat": "error p50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 5 },
          "unit": "s"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Time-to-publish proxy (FFmpeg p95)",
      "description": "PromQL only sees ffmpeg duration. True time-to-publish (uploaded → approved) requires the audit_logs SQL query in MONITORING_MODULE_35.md §3 — this panel is a LOWER BOUND. Add a Postgres data source for the real metric.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(product_video_ffmpeg_duration_seconds_bucket[1h])))",
          "legendFormat": "ffmpeg-only p95 (1h)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 5 },
          "unit": "s"
        }
      }
    },
    {
      "id": 300,
      "type": "row",
      "title": "3 · Errors",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 7,
      "type": "stat",
      "title": "FFmpeg failures (last 24 h)",
      "description": "Count of pipeline runs that ended in status=failed in the last day. Threshold: > 5/h sustained = systemic FFmpeg / source issue.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(product_video_failed_total[24h]))",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Bunny upload error rate",
      "description": "Error PUTs / total PUTs over 5 min, expressed as a percent. Threshold: > 1% sustained = Bunny side issue or auth rotation needed.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(rate(product_video_bunny_upload_duration_seconds_count{outcome=\"error\"}[5m])) / clamp_min(sum(rate(product_video_bunny_upload_duration_seconds_count[5m])), 1e-9)",
          "legendFormat": "error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "R2 upload error rate",
      "description": "R2 PUT failures / upload-endpoint requests, percent. Denominator uses the http_requests_total counter on the upload route (project-wide HTTP middleware) since there's no dedicated R2 success counter.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(rate(product_video_r2_upload_errors_total[5m])) / clamp_min(sum(rate(http_requests_total{route=\"/api/v1/product-videos/products/{product_id}/upload\"}[5m])), 1e-9)",
          "legendFormat": "error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 400,
      "type": "row",
      "title": "4 · Business",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 10,
      "type": "barchart",
      "title": "Moderation actions (rate, last 1 h)",
      "description": "Approve / reject / disable / reopen rates derived from http_requests_total on the matching admin endpoints. For 30-day historical totals use the audit_logs SQL queries in MONITORING_MODULE_35.md §2.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 28 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{route=\"/api/v1/admin/product-videos/{video_id}/approve\", status=\"200\"}[1h]))",
          "legendFormat": "approve",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "sum(rate(http_requests_total{route=\"/api/v1/admin/product-videos/{video_id}/reject\", status=\"200\"}[1h]))",
          "legendFormat": "reject",
          "instant": true
        },
        {
          "refId": "C",
          "expr": "sum(rate(http_requests_total{route=\"/api/v1/admin/product-videos/{video_id}/disable\", status=\"200\"}[1h]))",
          "legendFormat": "disable",
          "instant": true
        },
        {
          "refId": "D",
          "expr": "sum(rate(http_requests_total{route=\"/api/v1/admin/product-videos/{video_id}/reopen\", status=\"200\"}[1h]))",
          "legendFormat": "reopen",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "auto",
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Approval cap hits (last 24 h)",
      "description": "Sellers blocked by product_video_max_approved_per_product (default 3). High count = sellers want more videos per product. Consider raising the cap or surfacing a clearer error.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 28 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(product_video_approve_cap_hit_total[24h]))",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Public list QPS",
      "description": "Customer-side traffic on GET /products/{id}/videos. Big drops vs week-over-week = frontend not calling the endpoint (player rail removed?) — check the customer-web deploy.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 28 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{route=\"/api/v1/products/{product_id}/videos\"}[1m]))",
          "legendFormat": "QPS"
        },
        {
          "refId": "B",
          "expr": "sum by (event_type) (rate(product_video_event_post_total[1m]))",
          "legendFormat": "event {{event_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 5 },
          "unit": "reqps"
        }
      }
    }
  ]
}
