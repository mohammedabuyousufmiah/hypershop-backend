# Hypershop — production environment template
# Copy to `.env` next to docker-compose.prod.yml. NEVER commit the real file.
# Every variable below marked REQUIRED must be set or `docker compose` will
# refuse to start with an explicit "set XYZ" error.

# ════════════════════════════════════════════════════════════════════
# REQUIRED — fail-fast secrets (no defaults; compose / preflight exits if unset)
# ════════════════════════════════════════════════════════════════════

# Run mode. MUST be 'production' for go-live. Accepted values:
#   dev | test | staging | production
# Anything other than 'production' relaxes a long list of safety checks
# (CORS origins, cookie SameSite, logging verbosity) — never ship dev here.
ENVIRONMENT=production

# Postgres (used by both the postgres container init AND the DSN strings)
POSTGRES_DB=hypershop
POSTGRES_USER=hypershop
POSTGRES_PASSWORD=                # CHANGE — strong random, 32+ chars

# JWT signing key. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=                       # CHANGE — must be ≥ 32 chars random

# Comma-separated list of allowed frontend origins. PRODUCTION MUST be
# HTTPS only — preflight will reject any http:// entry when ENVIRONMENT=production.
# Example:
#   CORS_ORIGINS=https://hypershop.com.bd,https://admin.hypershop.com.bd,https://seller.hypershop.com.bd
CORS_ORIGINS=

# Real SMTP relay (NO mailpit in prod). Examples:
#   AWS SES:   email-smtp.<region>.amazonaws.com:587
#   SendGrid:  smtp.sendgrid.net:587
#   Postmark:  smtp.postmarkapp.com:587
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_SENDER=no-reply@hypershop.example

# ════════════════════════════════════════════════════════════════════
# OPTIONAL — initial admin (recommended; otherwise no one can log in
#             after first deploy until you run create-superuser by hand)
# ════════════════════════════════════════════════════════════════════
# If both are set, the `bootstrap` service creates the user, marks email
# verified, and grants the `admin` role. Idempotent — re-deploys won't
# duplicate the user but WILL reset its password to whatever's here.
# Best practice: set on first deploy, then unset and rotate password
# via the API or `make prod-create-superuser` for subsequent deploys.
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=

# ════════════════════════════════════════════════════════════════════
# OPTIONAL — TLS overlay (only needed if you use docker-compose.tls.yml)
# ════════════════════════════════════════════════════════════════════
API_DOMAIN=
ACME_EMAIL=

# ════════════════════════════════════════════════════════════════════
# OPTIONAL — backup tuning
# ════════════════════════════════════════════════════════════════════
BACKUP_INTERVAL_SECONDS=86400      # 24h between auto pg_dumps
BACKUP_RETENTION_DAYS=14           # delete dumps older than this

# ════════════════════════════════════════════════════════════════════
# OPTIONAL — overrides for tunables (defaults are sane for prod)
# ════════════════════════════════════════════════════════════════════

LOG_LEVEL=INFO
API_PORT=8000
API_PREFIX=/api/v1

# DB pool — tune to (gunicorn workers × pool_size) ≤ Postgres max_connections
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# JWT lifetimes
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# Argon2 — raise time/memory cost on stronger hosts
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST_KIB=65536
ARGON2_PARALLELISM=4

# Rate limits (per-user, Redis-backed)
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_OTP_PER_HOUR=5
RATE_LIMIT_REGISTER_PER_HOUR=10

# OTP / password policy
OTP_LENGTH=6
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=5
PASSWORD_RESET_TTL_SECONDS=3600
PASSWORD_MIN_LENGTH=12

# Account lockout (failed-login throttle)
FAILED_LOGIN_LOCKOUT_THRESHOLD=10
FAILED_LOGIN_LOCKOUT_SECONDS=900

# ARQ worker
ARQ_QUEUE_NAME=hypershop:jobs

# Inventory
INVENTORY_DEFAULT_WAREHOUSE_CODE=MAIN
INVENTORY_NEAR_EXPIRY_DAYS=30
INVENTORY_EXPIRY_CHECK_INTERVAL_MINUTES=60

# Prescription / wallet / delivery files. The compose file mounts named
# volumes at these exact paths inside the api+worker containers — do NOT
# change the values; change the volume backing in compose if you need
# different host storage.
PRESCRIPTION_MAX_FILE_BYTES=10485760
WALLET_CREDIT_LIFETIME_DAYS=30
WALLET_ROLLOVER_PERCENT=0
WALLET_CURRENCY=BDT
DELIVERY_POD_MAX_FILE_BYTES=8388608
DELIVERY_COD_AUTO_RECONCILE_TOLERANCE_CENTS=0

# Reminders (BDT = UTC+6)
REMINDER_MORNING_HHMM=08:00
REMINDER_AFTERNOON_HHMM=14:00
REMINDER_NIGHT_HHMM=21:00
REMINDER_LOCAL_TZ_OFFSET_HOURS=6
REMINDER_DISPATCH_INTERVAL_MINUTES=5
REMINDER_DISPATCH_BATCH_SIZE=200

# Finance — VAT rate. BD medicines mostly exempt → keep 0. "0.15" = 15%.
VAT_RATE=0

# ════════════════════════════════════════════════════════════════════
# OPTIONAL — external provider chains (default `none` → 502 with message)
# ════════════════════════════════════════════════════════════════════

# AI: openai | anthropic | gemini | none
AI_PROVIDER=none
AI_BACKUP_PROVIDERS=

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL_DEFAULT=

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL_DEFAULT=

GEMINI_API_KEY=
GEMINI_BASE_URL=
GEMINI_MODEL_DEFAULT=

# Drug data: bnf | bd_formulary | none
FORMULARY_PROVIDER=none
FORMULARY_API_KEY=
FORMULARY_BASE_URL=

# ════════════════════════════════════════════════════════════════════
# OPTIONAL — payment gateways (Module 22; default `none` → 502)
# ════════════════════════════════════════════════════════════════════

# Default gateway: bkash | sslcommerz | nagad | rocket | none
PAYMENT_PROVIDER=none
# Public origin where customers land after gateway redirect (your frontend)
PAYMENT_DEFAULT_REDIRECT_BASE_URL=
# Public FQDN of THIS api service (gateways POST IPNs here)
PAYMENT_WEBHOOK_BASE_URL=

# Bkash Tokenized Checkout
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_BASE_URL=
BKASH_WEBHOOK_URL=

# SSLCommerz
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWD=
SSLCOMMERZ_BASE_URL=
SSLCOMMERZ_IS_SANDBOX=false
SSLCOMMERZ_WEBHOOK_URL=

# Nagad (PEM strings — preserve newlines)
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_NUMBER=
NAGAD_MERCHANT_PRIVATE_KEY_PEM=
NAGAD_PUBLIC_KEY_PEM=
NAGAD_BASE_URL=
NAGAD_IS_SANDBOX=false
NAGAD_CALLBACK_BASE_URL=
NAGAD_WEBHOOK_URL=

# Rocket (DBBL direct merchant API; skip if using SSLCommerz aggregator)
ROCKET_MERCHANT_ID=
ROCKET_APP_KEY=
ROCKET_APP_SECRET=
ROCKET_BASE_URL=
ROCKET_IS_SANDBOX=false
ROCKET_WEBHOOK_URL=

# ════════════════════════════════════════════════════════════════════
# OPTIONAL — SMS provider (Module 23; default `none` → 503 on dispatch)
# ════════════════════════════════════════════════════════════════════
# bulksmsbd | ssl_wireless | twilio | none
SMS_PROVIDER=none

# BulkSMSBD
BULKSMSBD_API_KEY=
BULKSMSBD_SENDER_ID=
BULKSMSBD_BASE_URL=

# SSL Wireless
SSL_WIRELESS_API_TOKEN=
SSL_WIRELESS_SID=
SSL_WIRELESS_BASE_URL=

# Twilio (international fallback)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_BASE_URL=

# ════════════════════════════════════════════════════════════════════
# RECOMMENDED — WhatsApp invoice + OTP delivery (Module 24)
# ════════════════════════════════════════════════════════════════════
# Routing:  +880... → WhatsApp → SMS fallback;  non-BD → WhatsApp only
WHATSAPP_PROVIDER=none

WHATSAPP_TEMPLATE_INVOICE=hypershop_invoice
WHATSAPP_TEMPLATE_INVOICE_LANGUAGE=en
WHATSAPP_TEMPLATE_OTP=hypershop_otp_authentication
WHATSAPP_TEMPLATE_OTP_LANGUAGE=en

# Meta Cloud API (https://developers.facebook.com/docs/whatsapp/cloud-api)
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
META_WHATSAPP_API_VERSION=v21.0
META_WHATSAPP_APP_SECRET=
META_WHATSAPP_VERIFY_TOKEN=

# Customer app download links — included in SMS invoice fallback
CUSTOMER_APP_ANDROID_URL=
CUSTOMER_APP_IOS_URL=

# ════════════════════════════════════════════════════════════════════
# OPTIONAL — Push notifications (Module 25)
# ════════════════════════════════════════════════════════════════════
FCM_SERVICE_ACCOUNT_JSON=
FCM_PROJECT_ID=

APNS_TEAM_ID=
APNS_KEY_ID=
APNS_PRIVATE_KEY_P8=
APNS_BUNDLE_ID=
APNS_IS_SANDBOX=false

# ════════════════════════════════════════════════════════════════════
# OPTIONAL — Search reranker (Module 28; default `none` = ts_rank order)
# ════════════════════════════════════════════════════════════════════
SEARCH_RERANK_PROVIDER=none
SEARCH_RERANK_API_URL=
SEARCH_RERANK_API_TOKEN=
SEARCH_RERANK_API_AUTH_HEADER=Authorization
SEARCH_RERANK_API_AUTH_SCHEME=Bearer
SEARCH_RERANK_API_METHOD=POST
SEARCH_RERANK_API_STATIC_HEADERS_JSON=
SEARCH_RERANK_TIMEOUT_S=8

# ════════════════════════════════════════════════════════════════════
# RECOMMENDED — Product page videos (Module 35)
# ════════════════════════════════════════════════════════════════════
# Single-VM deploys can leave R2_* empty and use the on-disk path.
# Multi-pod / k8s deploys MUST configure R2 (or another shared
# object store) so api + worker pods can hand HLS bundles between
# each other without a shared filesystem.

# On-disk root used only when R2_BUCKET_NAME is empty.
PRODUCT_VIDEO_STORAGE_DIR=/var/hypershop/product_videos
# Hard cap per upload, in megabytes.
PRODUCT_VIDEO_MAX_SIZE_MB=200
# Reject probed uploads longer than this. 60 s = current production
# bound; lower to 30 s if you need 720p variants to fit inside 2-5 MB.
PRODUCT_VIDEO_MAX_DURATION_SECONDS=60
# APPROVED videos per product. 409 once hit.
PRODUCT_VIDEO_MAX_APPROVED_PER_PRODUCT=3
# Days to keep the raw original on R2 after a video reaches a
# terminal state (approved/rejected/disabled). HLS on Bunny lives
# forever (or until admin delete).
PRODUCT_VIDEO_RAW_RETENTION_DAYS=60
# FFmpeg jobs the worker may run per 30s tick.
PRODUCT_VIDEO_MAX_CONCURRENT_JOBS=2
# When R2_PUBLIC_BASE_URL is set, this is ignored — public URLs are
# built against R2's CDN. Otherwise point at your CDN that fronts
# PRODUCT_VIDEO_STORAGE_DIR. Empty = serve through the API.
PRODUCT_VIDEO_PUBLIC_BASE_URL=

# ════════════════════════════════════════════════════════════════════
# OPTIONAL — Cloudflare R2 / S3-compatible object storage
# ════════════════════════════════════════════════════════════════════
# Endpoint is derived from R2_ACCOUNT_ID:
#   https://<account_id>.r2.cloudflarestorage.com
# Set R2_BUCKET_NAME to switch product_videos uploads + HLS output
# from on-disk to R2. The worker reads/writes via boto3.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public CDN URL fronting the bucket's public prefix
# (e.g. https://cdn.hypershop.com).
R2_PUBLIC_BASE_URL=
R2_PRIVATE_PREFIX=raw/product-videos/
R2_PUBLIC_PREFIX=public/product-videos/

# ════════════════════════════════════════════════════════════════════
# RECOMMENDED — Bunny.net Storage Zone + Pull Zone CDN (Module 35)
# ════════════════════════════════════════════════════════════════════
# Pipeline:
#   raw upload      → R2 private prefix (purged after retention)
#   FFmpeg HLS+thumb → Bunny Storage Zone (this block)
#   customer playback → Bunny Pull Zone CDN
#
# Bunny Storage is NOT S3-compatible — the adapter speaks Bunny's
# plain HTTP API. Set BUNNY_STORAGE_REGION=sg for BD customer base
# (Singapore edge has the lowest BD latency).
BUNNY_STORAGE_ZONE_NAME=
BUNNY_STORAGE_ACCESS_KEY=
BUNNY_STORAGE_REGION=sg
BUNNY_PULL_ZONE_HOSTNAME=
BUNNY_PATH_PREFIX=product-videos/

# ════════════════════════════════════════════════════════════════════
# OPTIONAL — OpenTelemetry tracing + observability overlay
# ════════════════════════════════════════════════════════════════════
# Only required when layering docker-compose.observability.prod.yml
# (i.e. `make prod-up-observability`). The base prod stack runs fine
# without these — tracing is OFF until OTEL_EXPORTER_OTLP_ENDPOINT
# is set, and the observability overlay sets that for you.
OTEL_TRACES_SAMPLE_RATIO=0.1     # 10% sampling — see docs/OBSERVABILITY_TRACING.md
OTEL_ENVIRONMENT=production
JAEGER_RETENTION_DAYS=7          # Badger TTL — older spans are dropped
PROMETHEUS_RETENTION_DAYS=30     # tsdb retention — adjust to your disk budget

# Observability subdomain — DNS A/AAAA record must point at this host.
# Caddy auto-provisions a Let's Encrypt cert on first request.
OBSERVABILITY_DOMAIN=obs.api.hypershop.example

# Basic auth for the Jaeger / Prometheus / Grafana UIs. Generate the
# hash with:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-pw'
# Then paste the bcrypt hash below. Username is whatever you pick
# (commonly `admin`).
OBSERVABILITY_USER=admin
OBSERVABILITY_PASSWORD_HASH=

# Initial Grafana admin password (used on first start to seed the
# admin account; rotate via Grafana UI afterwards).
GRAFANA_ADMIN_PASSWORD=
