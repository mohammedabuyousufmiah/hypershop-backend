{
  "$schema": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainer.schema.json",
  "name": "hypershop-backend-devcontainer",

  // Base: official Python 3.12 image — matches the production Dockerfile pin.
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",

  // Features add CLIs and runtimes the host machine doesn't have.
  "features": {
    // Docker-in-Docker — needed for `make prod-up`, `docker compose`,
    // `pytest` (testcontainers spins up Postgres+Redis containers).
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": true,
      "version": "latest"
    },
    // GitHub CLI — handy for `gh codespace ssh` workflows.
    "ghcr.io/devcontainers/features/github-cli:1": {},
    // make + apt-get a few extras the project uses.
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false,
      "username": "vscode"
    }
  },

  // Auto-forward the api + mailpit web UI ports so they're clickable
  // from the Codespaces UI when running `make prod-up`.
  "forwardPorts": [8000, 8025, 5432, 6379],
  "portsAttributes": {
    "8000": {"label": "Hypershop API", "onAutoForward": "openPreview"},
    "8025": {"label": "Mailpit (dev SMTP UI)", "onAutoForward": "ignore"},
    "5432": {"label": "Postgres", "onAutoForward": "ignore"},
    "6379": {"label": "Redis", "onAutoForward": "ignore"}
  },

  // Larger machine — needed because `make prod-up` builds two Docker
  // images + spins up 6 containers (postgres, redis, mailpit, api,
  // worker, pg_backup). Default 2-core / 8 GB Codespace works but is
  // slow; 4-core / 16 GB is recommended for the test suite.
  "hostRequirements": {
    "cpus": 4,
    "memory": "16gb",
    "storage": "32gb"
  },

  // Run after the container is created (one-time setup).
  "postCreateCommand": "bash .devcontainer/postCreate.sh",

  // VS Code customisations — same extensions the team uses.
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.mypy-type-checker",
        "charliermarsh.ruff",
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml",
        "tamasfe.even-better-toml"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.unittestEnabled": false,
        "[python]": {
          "editor.formatOnSave": true,
          "editor.defaultFormatter": "charliermarsh.ruff"
        },
        "ruff.lint.run": "onSave"
      }
    }
  },

  // Run as `vscode` user (uid 1000) to match the production Dockerfile.
  "remoteUser": "vscode",

  // Mount the workspace at /workspaces (Codespaces convention).
  "workspaceFolder": "/workspaces/hypershop_fastapi_backend"
}
