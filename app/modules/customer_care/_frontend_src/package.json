{
  "name": "agent-inbox",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Real-time agent inbox for the WhatsApp Customer Care PWA backend.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4173",
