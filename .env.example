# Hypershop FastAPI backend — environment variables
# Copy to `.env` for local dev. NEVER commit a real `.env`.
# Production secrets must come from your secrets manager, not from a file.

# ----- Environment -----
ENVIRONMENT=dev
LOG_LEVEL=INFO

# ----- Service -----
SERVICE_NAME=hypershop-api
API_PREFIX=/api/v1

# ----- Database (asyncpg) -----
DATABASE_URL=postgresql+asyncpg://hypershop:hypershop@postgres:5432/hypershop
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5
DATABASE_POOL_RECYCLE_SECONDS=1800

# Sync URL (used by Alembic only). Same DB, different driver.
DATABASE_SYNC_URL=postgresql+psycopg2://hypershop:hypershop@postgres:5432/hypershop

# ----- Redis -----
REDIS_URL=redis://redis:6379/0

# ----- JWT -----
# Generate via: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-min-32-chars-use-real-secret-in-production
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# ----- Argon2 password hashing -----
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST_KIB=65536
ARGON2_PARALLELISM=4

# ----- Rate limiting -----
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_OTP_PER_HOUR=5
RATE_LIMIT_REGISTER_PER_HOUR=10

# ----- OTP -----
OTP_LENGTH=6
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=5

# ----- Password reset -----
PASSWORD_RESET_TTL_SECONDS=3600
PASSWORD_MIN_LENGTH=12

# ----- Account lockout -----
FAILED_LOGIN_LOCKOUT_THRESHOLD=10
FAILED_LOGIN_LOCKOUT_SECONDS=900

# ----- CORS (comma-separated; empty = no cross-origin requests allowed) -----
CORS_ORIGINS=http://localhost:3000

# ----- SMTP (required once Phase 1 / IAM is enabled) -----
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_SENDER=no-reply@hypershop.local

# ----- ARQ worker -----
ARQ_QUEUE_NAME=hypershop:jobs

# ----- Inventory -----
INVENTORY_DEFAULT_WAREHOUSE_CODE=MAIN
INVENTORY_NEAR_EXPIRY_DAYS=30
INVENTORY_EXPIRY_CHECK_INTERVAL_MINUTES=60

# ----- Prescriptions -----
# Directory where uploaded prescription files are stored. Must be on a
# persistent volume in production (NEVER /tmp on a multi-pod deployment).
PRESCRIPTION_STORAGE_DIR=/var/hypershop/prescriptions
PRESCRIPTION_MAX_FILE_BYTES=10485760

# ----- Doctor prescriptions + customer wallet -----
DOCTOR_RX_PDF_DIR=/var/hypershop/doctor_rx_pdfs
WALLET_CREDIT_LIFETIME_DAYS=30
# Set 0 = no rollover, 100 = full rollover, 25 = 25% of unspent rolls into next period
WALLET_ROLLOVER_PERCENT=0
WALLET_CURRENCY=BDT

# ----- Medication reminders -----
REMINDER_MORNING_HHMM=08:00
REMINDER_AFTERNOON_HHMM=14:00
REMINDER_NIGHT_HHMM=21:00
# BDT = UTC+6
REMINDER_LOCAL_TZ_OFFSET_HOURS=6
REMINDER_DISPATCH_INTERVAL_MINUTES=5
REMINDER_DISPATCH_BATCH_SIZE=200

# ----- Delivery operations (rider POD + COD) -----
DELIVERY_POD_DIR=/var/hypershop/delivery_pod
DELIVERY_POD_MAX_FILE_BYTES=8388608
# 0 = exact match required; 50 = ±50 BDT-cents auto-reconcile
DELIVERY_COD_AUTO_RECONCILE_TOLERANCE_CENTS=0

# ----- Finance / accounting -----
# VAT-inclusive output rate. Bangladesh medicines mostly VAT-exempt → keep 0.
# Example: "0.15" = 15%.
VAT_RATE=0

# ----- AI providers (Module 20) -----
# Primary provider: openai | anthropic | gemini | none
# `none` keeps NotConfiguredProvider bound — every AI call returns 502
# with a clear "missing setting" message. Set to a real provider only
# after you supply the matching *_API_KEY below.
AI_PROVIDER=none
# Comma-separated failover chain, e.g. "anthropic,gemini". Each backup
# must itself be configured; unconfigured entries are skipped + logged.
AI_BACKUP_PROVIDERS=

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL_DEFAULT=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL_DEFAULT=

# Google Gemini
GEMINI_API_KEY=
GEMINI_BASE_URL=
GEMINI_MODEL_DEFAULT=

# ---------------------------------------------------------------------------
# Social login (mobile Google / Huawei Sign-In)  —  POST /api/v1/auth/{google,huawei}
# ---------------------------------------------------------------------------
# The backend verifies the provider id_token's signature (provider JWKS),
# issuer, expiry, and AUDIENCE (`aud`) against the client IDs below.
# Leave BOTH empty to keep social login DISABLED — the endpoints then return
# HTTP 503 (no insecure stub-accept). No app rebuild is needed to flip these
# on; just set the value(s) and restart the API.
#
# Where the values come from:
#   GOOGLE → Google Cloud Console → APIs & Services → Credentials → OAuth 2.0
#            Client IDs. Use the WEB client ID the mobile app's id_token is
#            minted for (the `aud` claim). Multiple allowed, comma-separated
#            (e.g. android + web client IDs).
#   HUAWEI → AppGallery Connect → your project → Account Kit → OAuth Client ID.
#
# Examples (do NOT commit real values):
#   GOOGLE_OAUTH_CLIENT_IDS=1234567890-abcdef.apps.googleusercontent.com
#   HUAWEI_OAUTH_CLIENT_IDS=1099XXXXXXXXX
GOOGLE_OAUTH_CLIENT_IDS=
HUAWEI_OAUTH_CLIENT_IDS=

# ----- Formulary provider (Module 20) -----
# bnf | bd_formulary | none. `none` → 502 on /formulary/* until configured.
FORMULARY_PROVIDER=none
FORMULARY_API_KEY=
FORMULARY_BASE_URL=

# ----- Payment providers (Module 22) -----
# Default gateway used when /payments/initiate doesn't pass `provider`.
# bkash | sslcommerz | nagad | rocket | none
PAYMENT_PROVIDER=none
# Public base URL where customers land after gateway redirect.
PAYMENT_DEFAULT_REDIRECT_BASE_URL=http://localhost:3000
# Public base URL gateways post webhooks to. MUST be the public FQDN
# of THIS api service. Used to build the per-provider webhook URL,
# e.g. <BASE>/api/v1/payments/webhooks/bkash
PAYMENT_WEBHOOK_BASE_URL=http://localhost:8000

# Bkash Tokenized Checkout
# Sandbox base: https://tokenized.sandbox.bka.sh/v1.2.0-beta
# Live base:    https://tokenized.pay.bka.sh/v1.2.0-beta
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_BASE_URL=
BKASH_WEBHOOK_URL=

# SSLCommerz
# Sandbox base: https://sandbox.sslcommerz.com
# Live base:    https://securepay.sslcommerz.com
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWD=
SSLCOMMERZ_BASE_URL=
SSLCOMMERZ_IS_SANDBOX=true
SSLCOMMERZ_WEBHOOK_URL=

# Nagad
# Sandbox base: https://sandbox-ssl.mynagad.com:10443
# Live base:    https://api.mynagad.com:20002
# PEM strings — paste verbatim with newlines preserved (use single-quote
# in shell, or escape \n appropriately).
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_NUMBER=
NAGAD_MERCHANT_PRIVATE_KEY_PEM=
NAGAD_PUBLIC_KEY_PEM=
NAGAD_BASE_URL=
NAGAD_IS_SANDBOX=true
NAGAD_CALLBACK_BASE_URL=
NAGAD_WEBHOOK_URL=

# Rocket (DBBL Mobile Banking) — direct merchant API.
# If routing Rocket through SSLCommerz aggregator, leave these unset
# and use PAYMENT_PROVIDER=sslcommerz.
ROCKET_MERCHANT_ID=
ROCKET_APP_KEY=
ROCKET_APP_SECRET=
ROCKET_BASE_URL=
ROCKET_IS_SANDBOX=true
ROCKET_WEBHOOK_URL=

# ----- SMS provider (Module 23 — phone OTP) -----
# bulksmsbd | ssl_wireless | twilio | none
# `none` (default) → SMS dispatch raises 503 + the outbox dispatcher
# schedules retry. Email OTP path is unaffected.
SMS_PROVIDER=none

# BulkSMSBD (BD-native, easiest signup at https://bulksmsbd.net)
BULKSMSBD_API_KEY=
BULKSMSBD_SENDER_ID=
BULKSMSBD_BASE_URL=

# SSL Wireless (BD enterprise — register approved Sender ID first)
SSL_WIRELESS_API_TOKEN=
SSL_WIRELESS_SID=
SSL_WIRELESS_BASE_URL=

# Twilio (international fallback — needed only for non-BD numbers)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_BASE_URL=

# ----- WhatsApp transport (Module 24 — invoice + OTP delivery) -----
# meta_cloud | none. Default `none` → invoice/OTP fall through to SMS
# (BD only; non-BD requires WhatsApp).
#
# Routing rule (always):
#   +880... (BD)   → WhatsApp first → on fail → BulkSMSBD/SSL Wireless SMS
#   anything else → WhatsApp ONLY (no expensive intl SMS)
WHATSAPP_PROVIDER=none

# Template names registered on business.facebook.com — operator MUST
# create these in Meta's Business Manager before going live.
# Recommended template body for hypershop_invoice:
#   Hi {{1}}, your Hypershop order {{2}} is confirmed.
#   Total: {{3}} {{4}}.
#   View invoice: {{5}}
WHATSAPP_TEMPLATE_INVOICE=hypershop_invoice
WHATSAPP_TEMPLATE_INVOICE_LANGUAGE=en
# OTP template (Meta auto-approves the AUTHENTICATION category):
#   Your Hypershop verification code is {{1}}. It expires in {{2}} minutes.
WHATSAPP_TEMPLATE_OTP=hypershop_otp_authentication
WHATSAPP_TEMPLATE_OTP_LANGUAGE=en

# Meta Cloud API
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
META_WHATSAPP_API_VERSION=v21.0
# Used to verify X-Hub-Signature-256 on inbound webhooks (delivery
# receipts). Find under business.facebook.com -> App -> Settings ->
# Basic -> "App Secret".
META_WHATSAPP_APP_SECRET=
# Arbitrary string YOU pick; paste the same value into Meta's webhook
# config UI ("Verify Token"). Used in the GET handshake.
META_WHATSAPP_VERIFY_TOKEN=

# ----- Customer app download links (used in SMS invoice fallback) -----
CUSTOMER_APP_ANDROID_URL=
CUSTOMER_APP_IOS_URL=

# ----- Push notifications (Module 25) -----
# FCM HTTP v1 — paste the WHOLE service-account JSON as a single env
# value. Example: FCM_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# (single quotes preserve the inner JSON; private_key escapes with \n).
FCM_SERVICE_ACCOUNT_JSON=
FCM_PROJECT_ID=

# APNS — token-based auth. Paste the contents of the .p8 key file (PEM)
# verbatim, preserving newlines. Single-quote in shell to keep \n literal.
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_PRIVATE_KEY_P8=
APNS_BUNDLE_ID=
APNS_IS_SANDBOX=true

# ----- Search reranker (Module 28) -----
# external_ml | none. Default `none` keeps Postgres ts_rank order;
# the search endpoint stays up regardless. Configure external_ml
# to point at any HTTP endpoint that takes
#   {"query": "...", "candidates": [{"id":"...","title":"..."}, ...]}
# and returns either
#   {"results": [{"id":"...","score": 0.91}, ...]}
# or
#   {"scores": {"id1": 0.91, "id2": 0.42}}
SEARCH_RERANK_PROVIDER=none
SEARCH_RERANK_API_URL=
SEARCH_RERANK_API_TOKEN=
SEARCH_RERANK_API_AUTH_HEADER=Authorization
SEARCH_RERANK_API_AUTH_SCHEME=Bearer
SEARCH_RERANK_API_METHOD=POST
# Optional extra headers as a JSON object string, e.g. {"X-Tenant":"hypershop"}
SEARCH_RERANK_API_STATIC_HEADERS_JSON=
SEARCH_RERANK_TIMEOUT_S=8

# ----- OpenTelemetry tracing (project-wide; OFF by default) -----
# Set OTEL_EXPORTER_OTLP_ENDPOINT to enable. Examples:
#   - Local Jaeger:    http://jaeger:4318
#   - Local Tempo:     http://tempo:4318
#   - Grafana Cloud:   https://otlp-gateway-prod-<region>.grafana.net/otlp
#   - Honeycomb:       https://api.honeycomb.io
# When unset, tracing is fully disabled — no SDK init, no overhead.
OTEL_EXPORTER_OTLP_ENDPOINT=
# Auth headers for the collector, comma-separated key=value pairs.
# Example for Honeycomb: "x-honeycomb-team=YOUR_API_KEY"
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=hypershop-api
OTEL_ENVIRONMENT=dev
# Sample ratio: 1.0 = every span (dev), 0.1–0.25 typical for prod.
OTEL_TRACES_SAMPLE_RATIO=1.0

# ----- Product page videos (Module 35) -----
# On-disk root for original uploads + generated HLS + posters when NOT
# using R2 (i.e. R2_BUCKET_NAME is empty). Must be on a persistent
# volume in production. Ignored entirely once R2_BUCKET_NAME is set.
PRODUCT_VIDEO_STORAGE_DIR=/var/hypershop/product_videos
# Hard cap on a single upload, in megabytes. Default 200 MB.
PRODUCT_VIDEO_MAX_SIZE_MB=200
# Reject probed uploads longer than this. At 60 s the 720p variant
# lands ~9 MB and 360p ~3 MB; lower to 30 s if you need a tight
# 2–5 MB-per-variant size budget.
PRODUCT_VIDEO_MAX_DURATION_SECONDS=60
# Hard ceiling on APPROVED videos per product. The approve endpoint
# returns 409 once a product hits this; existing videos must be
# disabled/rejected before another can be approved.
PRODUCT_VIDEO_MAX_APPROVED_PER_PRODUCT=3
# Days the raw original is kept on R2 (or disk) after a video reaches
# a terminal state (approved / rejected / disabled). The HLS bundle on
# Bunny is NOT affected — only the private raw is purged. ``failed``
# rows are never auto-purged so an operator can debug the FFmpeg crash.
PRODUCT_VIDEO_RAW_RETENTION_DAYS=60
# FFmpeg jobs the worker may run per 30s tick (each ~1 CPU).
PRODUCT_VIDEO_MAX_CONCURRENT_JOBS=2
# When set, public video URLs are built against this base instead
# of /api/v1/catalog/videos/files. Independent of R2 — see R2 block.
PRODUCT_VIDEO_PUBLIC_BASE_URL=

# ----- Cloudflare R2 / S3-compatible object storage (Module 35) -----
# Leave R2_BUCKET_NAME empty to keep using the on-disk path under
# PRODUCT_VIDEO_STORAGE_DIR. When set, raw uploads + HLS output go
# to R2; the worker reads/writes via boto3 against the R2 endpoint:
#   https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# The public prefix is expected to be served through Cloudflare's CDN
# under R2_PUBLIC_BASE_URL (e.g. https://cdn.hypershop.com); the
# private prefix is NOT public and is read only by the worker.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=
R2_PRIVATE_PREFIX=raw/product-videos/
R2_PUBLIC_PREFIX=public/product-videos/

# ----- Bunny.net Storage Zone + Pull Zone CDN (Module 35) -----
# Pipeline: raw upload lives on R2 (private). FFmpeg-compressed HLS +
# thumbnail go to Bunny Storage. Customers fetch from the Bunny Pull
# Zone CDN (b-cdn.net or your custom domain).
# Required when serving HLS through Bunny — the worker writes the
# Bunny CDN URL into product_videos.hls_url at the end of FFmpeg.
BUNNY_STORAGE_ZONE_NAME=
BUNNY_STORAGE_ACCESS_KEY=
# Storage region: empty = main DE zone (storage.bunnycdn.com).
# Other valid: ny la sg uk se br jh
# (singapore is closest to Bangladesh — set BUNNY_STORAGE_REGION=sg)
BUNNY_STORAGE_REGION=
# Pull Zone hostname (without scheme). e.g. hypershop-vid.b-cdn.net
# or your custom domain attached to the pull zone in Bunny dashboard.
BUNNY_PULL_ZONE_HOSTNAME=
# Path prefix inside the storage zone — keeps the zone tidy if you
# host other apps' assets in the same zone.
BUNNY_PATH_PREFIX=product-videos/
